<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/navy" android:padding="14dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Settings" android:textSize="26sp" android:textStyle="bold" android:textColor="@color/white" android:layout_marginBottom="20dp"/>
        <TextView android:id="@+id/tvCatList" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="15sp" android:textColor="@color/silver_l" android:lineSpacingExtra="6dp" android:layout_marginBottom="12dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <EditText android:id="@+id/etNewCat" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:background="@drawable/input_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:hint="New category name" android:textColor="@color/white" android:textColorHint="@color/muted" android:textSize="15sp" android:inputType="text" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnAddCat" android:layout_width="wrap_content" android:layout_height="44dp" android:text="+ Add" android:textSize="13sp" android:backgroundTint="@color/amber" android:textColor="@color/navy_dark"/>
        </LinearLayout>
        <Button android:id="@+id/btnResetCats" android:layout_width="wrap_content" android:layout_height="36dp" android:text=" Reset to defaults" android:textSize="12sp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="@color/muted" app:strokeColor="@color/border" android:layout_marginTop="8dp" android:layout_marginBottom="16dp"/>
        <TextView android:id="@+id/tvZoneList" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textColor="@color/silver_l" android:fontFamily="monospace" android:lineSpacingExtra="6dp" android:layout_marginBottom="12dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
            <EditText android:id="@+id/etNewZoneName" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:background="@drawable/input_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:hint="Zone name" android:textColor="@color/white" android:textColorHint="@color/muted" android:textSize="14sp" android:inputType="text" android:layout_marginEnd="8dp"/>
            <EditText android:id="@+id/etNewZoneCode" android:layout_width="100dp" android:layout_height="44dp" android:background="@drawable/input_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:hint="CODE" android:textColor="@color/white" android:textColorHint="@color/muted" android:textSize="14sp" android:inputType="textCapCharacters"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnAddZone" android:layout_width="wrap_content" android:layout_height="44dp" android:text="+ Add Zone" android:textSize="13sp" android:backgroundTint="@color/amber" android:textColor="@color/navy_dark" android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnResetZones" android:layout_width="wrap_content" android:layout_height="44dp" android:text=" Reset" android:textSize="12sp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="@color/muted" app:strokeColor="@color/border"/>
        </LinearLayout>
        <TextView android:id="@+id/tvVersion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="14sp" android:textColor="@color/silver" android:fontFamily="monospace" android:layout_marginTop="20dp"/>
    </LinearLayout>
</ScrollView>
