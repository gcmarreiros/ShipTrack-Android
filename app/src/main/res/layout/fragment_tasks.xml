<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/navy">

    <!-- Header row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="14dp" android:paddingEnd="8dp"
        android:paddingTop="12dp" android:paddingBottom="8dp">
        <TextView android:id="@+id/tvTaskCount"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="0 tasks"
            android:textSize="13sp" android:textColor="@color/muted"
            android:fontFamily="monospace"/>
        <Button android:id="@+id/btnToggleDone"
            android:layout_width="wrap_content" android:layout_height="38dp"
            android:text="&#x25CF; HIDE DONE" android:textSize="10sp"
            android:textColor="@color/muted" android:fontFamily="monospace"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnFilterCat"
            android:layout_width="wrap_content" android:layout_height="38dp"
            android:text="CAT" android:textSize="10sp" android:textColor="@color/muted"
            android:fontFamily="monospace"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnFilterPrio"
            android:layout_width="wrap_content" android:layout_height="38dp"
            android:text="PRIO" android:textSize="10sp" android:textColor="@color/muted"
            android:fontFamily="monospace"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnSort"
            android:layout_width="wrap_content" android:layout_height="38dp"
            android:text="SORT" android:textSize="10sp" android:textColor="@color/muted"
            android:fontFamily="monospace"
            style="@style/Widget.MaterialComponents.Button.TextButton"/>
    </LinearLayout>

    <!-- Search bar -->
    <EditText android:id="@+id/etSearch"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:background="@drawable/input_bg"
        android:paddingStart="14dp" android:paddingEnd="14dp"
        android:hint="Search tasks&#x2026;"
        android:textColor="@color/white" android:textColorHint="@color/muted"
        android:textSize="15sp" android:inputType="text"
        android:layout_marginStart="14dp" android:layout_marginEnd="14dp"
        android:layout_marginBottom="8dp"/>

    <!-- Task list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="14dp" android:paddingEnd="14dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"/>

    <!-- Empty state -->
    <LinearLayout android:id="@+id/emptyState"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center"
        android:padding="60dp" android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#x1F535;" android:textSize="48sp" android:alpha="0.4"
            android:layout_marginBottom="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No tasks" android:textSize="20sp"
            android:textColor="@color/silver" android:layout_marginBottom="6dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tap + to register a new task." android:textSize="14sp"
            android:textColor="@color/muted" android:gravity="center"/>
    </LinearLayout>

</LinearLayout>
