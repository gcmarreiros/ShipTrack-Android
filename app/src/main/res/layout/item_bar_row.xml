<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="8dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="3dp">
        <TextView android:id="@+id/tvBarLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Label" android:textSize="13sp" android:textColor="@color/silver_l" android:ellipsize="end" android:maxLines="1"/>
        <TextView android:id="@+id/tvBarCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="12sp" android:textColor="@color/muted" android:fontFamily="monospace"/>
    </LinearLayout>
    <ProgressBar android:id="@+id/progressBar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="3dp" android:max="100" android:progress="50" android:progressTint="@color/amber" android:progressBackgroundTint="@color/steel"/>
</LinearLayout>
