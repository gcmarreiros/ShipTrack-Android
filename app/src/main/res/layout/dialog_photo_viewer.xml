<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#000000">
    <ImageView android:id="@+id/ivPhoto" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="fitCenter" android:adjustViewBounds="true"/>
    <TextView android:id="@+id/tvCaption" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:background="#AA000000" android:textColor="#ffffff" android:textSize="13sp" android:fontFamily="monospace" android:padding="12dp"/>
    <Button android:id="@+id/btnClose" android:layout_width="44dp" android:layout_height="44dp" android:layout_gravity="top|end" android:layout_margin="12dp" android:text="X" android:textSize="24sp" android:textColor="#ffffff" android:backgroundTint="#66000000" android:padding="0dp"/>
</FrameLayout>