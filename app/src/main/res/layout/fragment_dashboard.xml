<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/navy" android:padding="14dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Yard Dashboard" android:textSize="26sp" android:textStyle="bold" android:textColor="@color/white"/>
                <TextView android:id="@+id/tvDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="@color/muted" android:fontFamily="monospace"/>
            </LinearLayout>
            <Button android:id="@+id/btnTheme" android:layout_width="40dp" android:layout_height="40dp" android:text="[theme]" android:textSize="18sp" android:padding="0dp" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/silver"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvRecent" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
        <LinearLayout android:id="@+id/catBarsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
        <LinearLayout android:id="@+id/zoneBarsContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
        <include android:id="@+id/cardTotal" layout="@layout/item_stat_card" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <include android:id="@+id/cardCrit" layout="@layout/item_stat_card" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <include android:id="@+id/cardOpen" layout="@layout/item_stat_card" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <include android:id="@+id/cardInProg" layout="@layout/item_stat_card" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <include android:id="@+id/cardDone" layout="@layout/item_stat_card" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        <include android:id="@+id/cardPhotos" layout="@layout/item_stat_card" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
    </LinearLayout>
</ScrollView>
