<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/navy_mid">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:background="@color/navy_dark" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="18dp" android:paddingEnd="8dp" android:elevation="4dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvFormTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Register Task" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white"/>
            <TextView android:id="@+id/tvFormSub" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NEW ENTRY" android:textSize="11sp" android:textColor="@color/green_sub" android:fontFamily="monospace"/>
        </LinearLayout>
        <Button android:id="@+id/btnClose" android:layout_width="44dp" android:layout_height="44dp" android:text="" android:textSize="24sp" android:textColor="@color/muted" android:padding="0dp" style="@style/Widget.MaterialComponents.Button.TextButton"/>
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
            <EditText android:id="@+id/etTitle" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/input_bg" android:paddingStart="14dp" android:paddingEnd="14dp" android:hint="Describe the taskâ¦" android:textColor="@color/white" android:textColorHint="@color/muted" android:textSize="16sp" android:inputType="textMultiLine" android:layout_marginBottom="14dp"/>
            <Spinner android:id="@+id/spinnerType" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/input_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="14dp"/>
            <Spinner android:id="@+id/spinnerPriority" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/input_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="14dp"/>
            <Button android:id="@+id/btnPickZone" android:layout_width="match_parent" android:layout_height="48dp" android:text="Tap to select zones" android:textColor="@color/muted" android:textSize="14sp" android:background="@drawable/input_bg" android:gravity="start|center_vertical" android:paddingStart="14dp" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_marginBottom="14dp"/>
            <TextView android:id="@+id/tvSelectedZones" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="@color/teal_l" android:fontFamily="monospace" android:layout_marginBottom="14dp" android:visibility="gone"/>
            <EditText android:id="@+id/etDue" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/input_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:hint="Due date (YYYY-MM-DD)" android:textColor="@color/white" android:textColorHint="@color/muted" android:textSize="14sp" android:fontFamily="monospace" android:layout_marginBottom="14dp"/>
            <EditText android:id="@+id/etRef" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/input_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:hint="Ref / Asset ID e.g. P-203" android:textColor="@color/white" android:textColorHint="@color/muted" android:textSize="14sp" android:fontFamily="monospace" android:layout_marginBottom="14dp"/>
            <EditText android:id="@+id/etNotes" android:layout_width="match_parent" android:layout_height="100dp" android:background="@drawable/input_bg" android:paddingStart="14dp" android:paddingEnd="14dp" android:paddingTop="10dp" android:hint="Safety notes, instructionsâ¦" android:textColor="@color/white" android:textColorHint="@color/muted" android:textSize="15sp" android:inputType="textMultiLine" android:gravity="top" android:layout_marginBottom="14dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                <Button android:id="@+id/btnCamera" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text=" Camera" android:textSize="13sp" android:backgroundTint="@color/card" android:textColor="@color/silver_l" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/btnGallery" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text=" Gallery" android:textSize="13sp" android:backgroundTint="@color/card" android:textColor="@color/silver_l"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvPhotoPreview" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="20dp" android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </ScrollView>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/navy_dark" android:orientation="horizontal" android:gravity="end" android:padding="14dp" android:elevation="4dp">
        <Button android:id="@+id/btnDeleteTask" android:layout_width="wrap_content" android:layout_height="44dp" android:text=" Delete" android:textSize="14sp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#e86040" app:strokeColor="#66c0401a" android:visibility="gone" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnCancel" android:layout_width="wrap_content" android:layout_height="44dp" android:text="Cancel" android:textSize="14sp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="@color/silver_l" app:strokeColor="@color/border" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnSave" android:layout_width="wrap_content" android:layout_height="44dp" android:text=" Save" android:textSize="14sp" android:textStyle="bold" android:backgroundTint="@color/amber" android:textColor="@color/navy_dark"/>
    </LinearLayout>
</LinearLayout>
