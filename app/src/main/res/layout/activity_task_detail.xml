<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/navy_mid">

    <!-- HEADER -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/navy_dark" android:orientation="vertical"
        android:paddingStart="18dp" android:paddingEnd="8dp"
        android:paddingTop="14dp" android:paddingBottom="12dp" android:elevation="4dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvDetailTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Task Title" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white"/>
                <TextView android:id="@+id/tvDetailSub" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TASK 001 - Equipment" android:textSize="11sp" android:textColor="@color/green_sub" android:fontFamily="monospace" android:layout_marginTop="3dp"/>
            </LinearLayout>
            <Button android:id="@+id/btnDetailClose" android:layout_width="44dp" android:layout_height="44dp" android:text="X" android:textSize="24sp" android:textColor="@color/muted" android:padding="0dp" style="@style/Widget.MaterialComponents.Button.TextButton"/>
        </LinearLayout>
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="44dp" android:orientation="horizontal" android:layout_marginBottom="16dp">
                <Button android:id="@+id/btnStatusOpen" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="[O] OPEN" android:textSize="9sp" android:fontFamily="monospace" android:background="@drawable/status_btn_bg" android:textColor="@color/muted" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnStatusInProg" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="[>] IN PROG" android:textSize="9sp" android:fontFamily="monospace" android:background="@drawable/status_btn_bg" android:textColor="@color/muted" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnStatusDone" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="[v] DONE" android:textSize="9sp" android:fontFamily="monospace" android:background="@drawable/status_btn_bg" android:textColor="@color/muted" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnStatusHold" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="[X] HOLD ON" android:textSize="9sp" android:fontFamily="monospace" android:background="@drawable/status_btn_bg" android:textColor="@color/muted"/>
            </LinearLayout>
            <TextView android:id="@+id/tvPhotosLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="PHOTOS (0)" android:textSize="11sp" android:fontFamily="monospace" android:textColor="@color/green_sub" android:letterSpacing="0.1" android:layout_marginBottom="8dp"/>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvDetailPhotos" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false" android:layout_marginBottom="20dp"/>
        </LinearLayout>
    </ScrollView>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/navy_dark" android:orientation="horizontal" android:padding="12dp" android:elevation="4dp">
        <Button android:id="@+id/btnAddPhoto" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="[cam] Photo" android:textSize="13sp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="@color/silver_l" app:strokeColor="@color/border" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnDetailEdit" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="[edit] Edit" android:textSize="13sp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="@color/silver_l" app:strokeColor="@color/border" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnDetailShare" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:text="[share] Share" android:textSize="13sp" android:backgroundTint="@color/amber" android:textColor="@color/navy_dark"/>
    </LinearLayout>
</LinearLayout>
