<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ShipTrack" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/amber</item>
        <item name="colorPrimaryVariant">@color/navy_mid</item>
        <item name="colorOnPrimary">@color/navy_dark</item>
        <item name="colorSecondary">@color/teal</item>
        <item name="colorOnSecondary">@color/navy_dark</item>
        <item name="android:windowBackground">@color/navy</item>
        <item name="android:statusBarColor">@color/navy_dark</item>
        <item name="android:navigationBarColor">@color/navy_dark</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/silver</item>
        <item name="colorControlActivated">@color/amber</item>
        <item name="colorControlHighlight">#2200bfff</item>
    </style>
    <style name="QsButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:padding">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="rippleColor">@color/amber</item>
    </style>
    <style name="SheetDialog" parent="Theme.MaterialComponents.DayNight.BottomSheetDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>
